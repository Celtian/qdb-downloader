{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: main",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "args": ["."],
      "cwd": "${workspaceFolder}",
      "env": {
        "QDB_RENDERER_URL": "http://127.0.0.1:4200"
      },
      "preLaunchTask": "bun: prepare Electron debug",
      "outputCapture": "std"
    },
    {
      "name": "Angular: renderer",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "bun: renderer",
      "url": "http://127.0.0.1:4200/"
    }
  ]
}
