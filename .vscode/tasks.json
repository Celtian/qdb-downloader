{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "bun: build Electron",
      "type": "shell",
      "command": "bun run build:electron",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "bun: renderer",
      "type": "shell",
      "command": "bun run start:renderer",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building|Changes detected",
          "endsPattern": "Local:.*http://127\\.0\\.0\\.1:4200"
        }
      }
    },
    {
      "label": "bun: prepare Electron debug",
      "dependsOrder": "sequence",
      "dependsOn": ["bun: build Electron", "bun: renderer"],
      "problemMatcher": []
    },
    {
      "label": "bun: validate",
      "type": "shell",
      "command": "bun run validate",
      "problemMatcher": ["$tsc"]
    }
  ]
}
