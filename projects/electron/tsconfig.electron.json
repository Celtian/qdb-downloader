{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../.electron",
    "rootDir": ".",
    "lib": ["ES2022", "DOM"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "noEmit": false,
    "sourceMap": true,
    "types": ["node"]
