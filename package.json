{
  "name": "qdb-downloader",
  "version": "0.0.3",
  "description": "Create date-based Transfermarkt football-data snapshots",
  "author": {
    "name": "Dominik Hladík",
    "email": "dominik.hladik@seznam.cz",
    "url": "https://github.com/Celtian"
  },
  "homepage": "https://github.com/Celtian/qdb-downloader#readme",
  "bugs": {
    "url": "https://github.com/Celtian/qdb-downloader/issues"
  },
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "concurrently --kill-others-on-fail --names renderer,desktop \"bun run start:renderer\" \"bun run start:desktop\"",
    "start:renderer": "ng serve electrobun --host 127.0.0.1 --port 4200",
    "start:wsl": "concurrently --kill-others-on-fail --names renderer,backend \"bun run start:renderer:wsl\" \"bun run start:wsl:backend\"",
    "start:renderer:wsl": "ng serve electrobun --host 127.0.0.1 --port 4200 --proxy-config projects/electrobun/proxy.conf.json",
    "start:wsl:backend": "bun --watch projects/electrobun/desktop/wsl-server.ts",
    "start:desktop": "wait-on http://127.0.0.1:4200 && cross-env QDB_RENDERER_URL=http://127.0.0.1:4200 electrobun dev --watch",
    "start:docs": "ng serve docs",
    "build": "bun run build:renderer && bun run build:docs && bun run typecheck:desktop",
    "build:renderer": "ng build electrobun",
    "build:docs": "ng build docs --base-href /qdb-downloader/",
    "package:desktop": "bun run build:renderer && electrobun build --env=stable",
    "release:windows": "cross-env QDB_TARGETS=win-x64 electrobun build --env=stable",
    "typecheck": "bun run typecheck:angular && bun run typecheck:desktop",
    "typecheck:angular": "ng build electrobun --configuration development && ng build docs --configuration development --base-href /qdb-downloader/",
    "typecheck:desktop": "tsc -p projects/electrobun/tsconfig.desktop.json",
    "lint": "eslint . --max-warnings=0",
    "lint:staged": "lint-staged --relative",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "ng test electrobun --watch=false && ng test docs --watch=false && bun test projects/electrobun/desktop projects/electrobun/shared",
    "test:coverage": "ng test electrobun --watch=false --coverage && ng test docs --watch=false --coverage && bun test projects/electrobun/desktop projects/electrobun/shared --coverage",
    "validate": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "changelog": "auto-changelog -p",
    "version": "bun run changelog && git add CHANGELOG.md",
    "postversion": "git push && git push --follow-tags",
    "release:patch": "git checkout master && npm version patch -m \"chore(update): patch release %s 🐛\"",
    "release:minor": "git checkout master && npm version minor -m \"chore(update): release %s 🚀\"",
    "release:major": "git checkout master && npm version major -m \"chore(update): major release %s 💥\"",
    "prepare": "husky"
  },
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.5",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.4",
    "@fontsource/roboto": "^5.3.0",
    "electrobun": "^1.18.1",
    "express": "^5.1.0",
    "material-icons": "^1.13.14",
    "rxjs": "~7.8.0",
    "soccerbot": "^1.1.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-angular": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@angular-eslint/eslint-plugin": "^22.1.0",
    "@angular-eslint/eslint-plugin-template": "^22.1.0",
    "@angular-eslint/template-parser": "^22.1.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/three": "^0.180.0",
    "angular-eslint": "^22.1.0",
    "auto-changelog": "2.6.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.10"
  },
  "auto-changelog": {
    "remote": "none",
    "commitUrl": "https://github.com/Celtian/qdb-downloader/commit/{id}",
    "issueUrl": "https://github.com/Celtian/qdb-downloader/issues/{id}",
    "mergeUrl": "https://github.com/Celtian/qdb-downloader/pull/{id}",
    "compareUrl": "https://github.com/Celtian/qdb-downloader/compare/{from}...{to}"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Celtian/qdb-downloader.git"
  }
}
