{
  "name": "qdb-downloader",
  "version": "0.0.7",
  "description": "Create date-based Transfermarkt football-data snapshots",
  "author": {
    "name": "Dominik Hladík",
    "email": "dominik.hladik@seznam.cz",
    "url": "https://github.com/Celtian"
  },
  "homepage": "https://github.com/Celtian/qdb-downloader#readme",
  "bugs": {
    "url": "https://github.com/Celtian/qdb-downloader/issues"
  },
  "main": ".electron/electron/main.js",
  "scripts": {
    "ng": "ng",
    "create-version": "package-version-info -o projects/version-info.ts",
    "start": "bun run build:electron && concurrently --kill-others --names renderer,desktop \"bun run start:renderer\" \"bun run start:desktop\"",
    "start:renderer": "ng serve electron --host 127.0.0.1 --port 4200 --prebundle=false",
    "start:desktop": "wait-on http://127.0.0.1:4200 .electron/electron/main.js .electron/electron/preload.js && cross-env ELECTRON_RUN_AS_NODE= QDB_RENDERER_URL=http://127.0.0.1:4200 electron .",
    "start:docs": "ng serve docs",
    "build": "bun run build:renderer && bun run build:docs && bun run build:electron",
    "build:renderer": "ng build electron",
    "build:docs": "ng build docs --base-href /qdb-downloader/",
    "build:electron": "tsc -p projects/electron/tsconfig.electron.json",
    "forge": "cross-env npm_config_user_agent=npm/11.16.0 electron-forge",
    "package:desktop": "bun run build:renderer && bun run build:electron && bun run forge package",
    "release:windows": "bun run build:renderer && bun run build:electron && bun run forge make --platform=win32 --arch=x64",
    "typecheck": "bun run typecheck:angular && bun run typecheck:electron",
    "typecheck:angular": "ng build electron --configuration development && ng build docs --configuration development --base-href /qdb-downloader/",
    "typecheck:electron": "tsc -p projects/electron/tsconfig.electron.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:staged": "lint-staged --relative",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "ng test electron --watch=false && ng test docs --watch=false && vitest run --config tools/vitest.config.ts",
    "test:coverage": "ng test electron --watch=false --coverage && ng test docs --watch=false --coverage && vitest run --coverage --config tools/vitest.config.ts",
    "validate": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "changelog": "auto-changelog -p",
    "version": "bun run create-version && bun run changelog && git add CHANGELOG.md",
    "postversion": "git push && git push --follow-tags",
    "release:patch": "git checkout master && npm version patch -m \"chore(update): patch release %s 🐛\"",
    "release:minor": "git checkout master && npm version minor -m \"chore(update): release %s 🚀\"",
    "release:major": "git checkout master && npm version major -m \"chore(update): major release %s 💥\"",
    "prepare": "husky && bun run create-version"
  },
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.5",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.4",
    "@fontsource/roboto": "^5.3.0",
    "express": "^5.1.0",
    "material-icons": "^1.13.14",
    "ngx-app-version": "^3.0.0",
    "ngx-nullable": "^1.0.0",
    "rxjs": "~7.8.0",
    "soccerbot": "^1.1.2",
    "tslib": "^2.3.0",
    "update-electron-app": "3.1.1"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^22.1.0",
    "@angular-eslint/eslint-plugin-template": "^22.1.0",
    "@angular-eslint/template-parser": "^22.1.0",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-angular": "^21.2.0",
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/publisher-github": "7.11.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.1",
    "@types/node": "^24.10.1",
    "@types/three": "^0.180.0",
    "@vitest/coverage-v8": "^4.0.8",
    "angular-eslint": "^22.1.0",
    "auto-changelog": "2.6.0",
    "axe-core": "^4.12.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "43.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.1.0",
    "package-version-info": "^0.2.2",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.10"
  },
  "auto-changelog": {
    "remote": "none",
    "commitUrl": "https://github.com/Celtian/qdb-downloader/commit/{id}",
    "issueUrl": "https://github.com/Celtian/qdb-downloader/issues/{id}",
    "mergeUrl": "https://github.com/Celtian/qdb-downloader/pull/{id}",
    "compareUrl": "https://github.com/Celtian/qdb-downloader/compare/{from}...{to}"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Celtian/qdb-downloader.git"
  },
  "engines": {
    "node": ">=24.18 <25",
    "npm": "please-use-bun"
  }
}
